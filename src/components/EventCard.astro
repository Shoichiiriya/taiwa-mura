---
interface Props {
  title: string;
  date: Date;
  location?: string;
  description: string;
  applyUrl?: string;
  slug: string;
}

const { title, date, location, description, applyUrl, slug } = Astro.props;

const dateStr = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'short',
});
---

<article style="border: 1px solid var(--color-border); border-radius: 0.5rem; padding: 1.25rem;">
  <time style="font-size: 0.875rem; color: var(--color-muted);">{dateStr}</time>
  <h3 style="font-family: var(--font-heading); font-weight: 700; margin-top: 0.25rem; font-size: 1.125rem;">
    <a href={`/events/${slug}`} style="color: var(--color-text); text-decoration: none;">
      {title}
    </a>
  </h3>
  {location && (
    <p style="font-size: 0.875rem; color: var(--color-muted); margin-top: 0.25rem;">
      📍 {location}
    </p>
  )}
  <p style="font-size: 0.875rem; margin-top: 0.5rem; color: var(--color-text); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
    {description}
  </p>
  {applyUrl && (
    <a
      href={applyUrl}
      target="_blank"
      rel="noopener noreferrer"
      style="display: inline-block; margin-top: 0.75rem; font-size: 0.875rem; color: var(--color-brand); border: 1px solid var(--color-brand); padding: 0.25rem 0.75rem; border-radius: 0.25rem; text-decoration: none;"
    >
      申し込む →
    </a>
  )}
</article>
