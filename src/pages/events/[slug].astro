---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map(event => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const dateStr = event.data.date.toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric', weekday: 'short',
});
---

<Layout title={event.data.title} description={event.data.description}>
  <div style="max-width: 48rem; margin: 0 auto; padding: 3rem 1.5rem;">
    <a href="/events" style="font-size: 0.875rem; color: var(--color-muted); text-decoration: none;">
      ← イベント一覧
    </a>

    <time style="display: block; font-size: 0.875rem; color: var(--color-muted); margin-top: 1.5rem;">{dateStr}</time>
    <h1 style="font-family: var(--font-heading); font-size: 2rem; font-weight: 700; color: var(--color-text); margin-top: 0.5rem;">
      {event.data.title}
    </h1>
    {event.data.location && (
      <p style="color: var(--color-muted); margin-top: 0.25rem;">📍 {event.data.location}</p>
    )}

    <div style="margin-top: 2.5rem; line-height: 1.9; color: var(--color-text);">
      <Content />
    </div>

    {event.data.applyUrl && (
      <div style="margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid var(--color-border);">
        <a
          href={event.data.applyUrl}
          target="_blank"
          rel="noopener noreferrer"
          style="background: var(--color-brand); color: white; padding: 0.75rem 1.5rem; border-radius: 0.375rem; text-decoration: none; font-size: 0.9375rem; font-weight: 500;"
        >
          申し込む →
        </a>
      </div>
    )}
  </div>
</Layout>
