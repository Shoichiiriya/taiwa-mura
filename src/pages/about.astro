---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="たいわ村とは。哲学対話・対話散歩・読書会を行うコミュニティについて。">
  <div style="max-width: 48rem; margin: 0 auto; padding: 3rem 1.5rem;">
    <h1 style="font-family: var(--font-heading); font-size: 2rem; font-weight: 700; color: var(--color-text); margin-bottom: 2rem;">
      About
    </h1>

    <section style="margin-bottom: 3rem;">
      <h2 style="font-family: var(--font-heading); font-size: 1.375rem; font-weight: 700; color: var(--color-text); margin-bottom: 1rem;">
        たいわ村とは
      </h2>
      <div style="line-height: 1.9; color: var(--color-text);">
        <p>
          たいわ村は、哲学対話・対話散歩・読書会などを通じて、対話の文化を育むコミュニティです。
        </p>
        <p style="margin-top: 1rem;">
          「対話」とは、答えを出すためだけでなく、共に問い続けるための営みです。
          たいわ村は、そのような対話の場を日常の中に作り続けることを目指しています。
        </p>
        <p style="margin-top: 1rem;">
          <!-- TODO: 村についてのテキストをここに追加してください -->
        </p>
      </div>
    </section>

    <section style="margin-bottom: 3rem;">
      <h2 style="font-family: var(--font-heading); font-size: 1.375rem; font-weight: 700; color: var(--color-text); margin-bottom: 1rem;">
        主催
      </h2>
      <div style="line-height: 1.9; color: var(--color-text);">
        <!-- TODO: 主催者プロフィールをここに追加してください -->
        <p style="color: var(--color-muted);">（準備中）</p>
      </div>
    </section>

    <section>
      <h2 style="font-family: var(--font-heading); font-size: 1.375rem; font-weight: 700; color: var(--color-text); margin-bottom: 1rem;">
        お問い合わせ
      </h2>
      <p style="line-height: 1.9; color: var(--color-text);">
        活動へのご参加・コラボレーションのご相談は
        <a href="/links" style="color: var(--color-brand); text-decoration: none;">リンクページ</a>
        よりお気軽にご連絡ください。
      </p>
    </section>
  </div>
</Layout>
