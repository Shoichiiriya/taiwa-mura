---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const activities = await getCollection('activities');
  return activities.map(activity => ({
    params: { slug: activity.id },
    props: { activity },
  }));
}

const { activity } = Astro.props;
const { Content } = await render(activity);
---

<Layout title={activity.data.title} description={activity.data.tagline}>
  <div style="max-width: 48rem; margin: 0 auto; padding: 3rem 1.5rem;">
    <a href="/activities" style="font-size: 0.875rem; color: var(--color-muted); text-decoration: none;">
      ← 活動一覧
    </a>

    <h1 style="font-family: var(--font-heading); font-size: 2rem; font-weight: 700; color: var(--color-text); margin-top: 1.5rem;">
      {activity.data.title}
    </h1>
    <p style="color: var(--color-muted); margin-top: 0.5rem;">{activity.data.tagline}</p>
    {activity.data.frequency && (
      <p style="font-size: 0.875rem; color: var(--color-muted); margin-top: 0.25rem;">🗓 {activity.data.frequency}</p>
    )}

    <div style="margin-top: 2.5rem; line-height: 1.9; color: var(--color-text);" class="prose">
      <Content />
    </div>

    <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border);">
      <a href="/events" style="background: var(--color-brand); color: white; padding: 0.75rem 1.5rem; border-radius: 0.375rem; text-decoration: none; font-size: 0.9375rem; font-weight: 500;">
        イベントを見る →
      </a>
    </div>
  </div>
</Layout>
